#   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-
#  / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \
# `-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'
#
#               Example environment configuration
#
#   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-
#  / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \
# `-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'

# By default, the examples support both mnemonic-based and private key-based authentication
#
# You don't need to set both of these values, just pick the one that you prefer and set that one
MNEMONIC=
PRIVATE_KEY=

# Production MUST set NODE_ENV=production and leave NURO_LOCAL_DEV_OTP unset/false.
# Local only: fixed verify-email OTP (111111) for UI/debug — refuses to boot if combined with production.
# NURO_LOCAL_DEV_OTP=true

# SD3 Issuer webhook verification (HMAC-SHA256 over raw body).
# Required in production. If unset, /issuer-webhook accepts payloads without
# verification and logs a warning — useful for local development only.
ISSUER_WEBHOOK_SECRET=

# Shadow mode: verify signatures and log what would happen, but skip the
# actual card_transactions insert/update. Flip to 'false' or unset once
# reconciliation confirms SD3 events match expectations.
ISSUER_WEBHOOK_OBSERVE_ONLY=false
