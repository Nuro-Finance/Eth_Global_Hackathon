  "scripts": {
    "clean": "rm -rf artifacts cache out .next",
    "build": "next build",
    "start": "next start -p 2800",
    "dev": "doppler run -- next dev -p 2800 --turbopack",
    "dev:api": "doppler run -- tsx src/index.ts",
    "db:local": "bash scripts/local-dev-setup.sh",
    "db:migrate": "bash scripts/run-migrations.sh",
    "build:fe": "next build",
    "start:fe": "next start -p 2800",
    "dev:fe": "doppler run -- next dev -p 2800 --turbopack",
    "lint:fe": "next lint",
    "seed:demo": "tsx scripts/seed-demo-account.ts",
    "seed:extra-cards": "tsx scripts/seed-extra-cards.ts",
    "compile": "concurrently -c auto --names forge,hardhat '$npm_execpath run compile:forge' '$npm_execpath run compile:hardhat'",
    "compile:forge": "forge build",
    "compile:hardhat": "hardhat compile",
    "compile:hardhat:nvm": "bash scripts/compile-contracts.sh",
    "lint": "$npm_execpath run lint:js && $npm_execpath run lint:sol",
    "lint:fix": "eslint --fix '**/*.{js,ts,json}' && prettier --write . && solhint 'contracts/**/*.sol' --fix --noPrompt",
    "lint:js": "eslint '**/*.{js,ts,json}' && prettier --check .",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "test": "$npm_execpath run test:forge && $npm_execpath run test:hardhat",
    "test:forge": "forge test",
    "test:hardhat": "hardhat test",
    "typecheck:backend": "tsc --noEmit -p tsconfig.backend.json",
    "test:backend": "vitest run",
    "test:backend:watch": "vitest",
    "ci:backend": "npm run typecheck:backend && npm run test:backend",
    "prepare": "husky || true",
    "postinstall": "node scripts/postinstall-fix-ink-react.js"
  },
  "resolutions": {
    "ethers": "^5.7.2",
    "hardhat-deploy": "^0.12.1"
  },
