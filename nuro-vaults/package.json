{
  "name": "nuro-vaults",
  "version": "1.0.0",
  "description": "Nuro Vault Competition Engine",
  "scripts": {
    "compile":          "hardhat compile",
    "test":             "hardhat test --network hardhat",
    "deploy:sepolia:1": "hardhat run scripts/deploy/01_deploy_admin.ts --network baseSepolia",
    "deploy:sepolia:2": "hardhat run scripts/deploy/02_deploy_core.ts --network baseSepolia",
    "deploy:sepolia:3": "hardhat run scripts/deploy/03_deploy_lottery.ts --network baseSepolia",
    "deploy:mainnet:1": "hardhat run scripts/deploy/01_deploy_admin.ts --network base",
    "deploy:mainnet:2": "hardhat run scripts/deploy/02_deploy_core.ts --network base",
    "deploy:mainnet:3": "hardhat run scripts/deploy/03_deploy_lottery.ts --network base",
    "build:ts":         "tsc --noEmit"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.2.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "ethers": "^5.7.2",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "hh2",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.7",
    "@typechain/ethers-v5": "^11.1.2",
    "@typechain/hardhat": "^6.1.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "hardhat": "^2.22.4",
    "hardhat-gas-reporter": "^1.0.10",
    "typechain": "^8.3.2",
    "typescript": "^5.4.5"
  }
}
