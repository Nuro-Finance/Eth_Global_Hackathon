# Nuro Vault Competition Engine - Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Deployer wallet (must be funded on target network)
DEPLOYER_PRIVATE_KEY=

# Nuro multisig address
CASHLY_MULTISIG=0x749edFC84A28793ce150d4E7E71bcEe73C454b56

# Alchemy API key for RPC
ALCHEMY_API_KEY=_9N8BifmCJQFSN8-qn7u-

# Basescan API key for contract verification
BASESCAN_API_KEY=

# Chainlink VRF subscription ID (create at vrf.chain.link)
CHAINLINK_VRF_SUBSCRIPTION_ID=

# PostgreSQL connection string
DATABASE_URL=postgresql://nuro:nuro@localhost:5432/nuro_vaults

# Admin wallet addresses (comma-separated) for admin API signature verification
ADMIN_ADDRESSES=0x27FbEAD2B527AaDAf4EA7B3Af065244A3964ECBC,0x749edFC84A28793ce150d4E7E71bcEe73C454b56

# Network: baseSepolia | base
NETWORK=baseSepolia
