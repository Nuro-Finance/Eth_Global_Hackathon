#!/usr/bin/env sh
# Runs before `git push`. Blocks pushes that would fail backend CI.
# Skip with --no-verify if you REALLY need to (e.g., WIP branch push).
#
# Gate 1 — dependency verification (every imported package declared in package.json)
# Gate 2 — backend typecheck (tsconfig.backend.json scope)
# Gate 3 — Vitest unit tests

set -e

echo "[pre-push] Verifying all imports are declared in package.json..."
node scripts/verify-deps.js

echo "[pre-push] Running backend typecheck..."
npm run --silent typecheck:backend

echo "[pre-push] Running unit tests..."
npm run --silent test:backend

echo "[pre-push] All gates passed."
